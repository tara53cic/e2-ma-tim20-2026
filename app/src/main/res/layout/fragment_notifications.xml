<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/notificationsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvNotificationsTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Notifikacije"
        android:textColor="@color/primary"
        android:textSize="26sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <LinearLayout
        android:id="@+id/filterContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/btnAllNotifications"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Sve"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/background"
            android:background="@drawable/bg_filter_selected" />

        <TextView
            android:id="@+id/btnUnreadNotifications"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:gravity="center"
            android:text="Nepročitane"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:background="@drawable/bg_filter_unselected" />

        <TextView
            android:id="@+id/btnReadNotifications"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:gravity="center"
            android:text="Pročitane"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:background="@drawable/bg_filter_unselected" />

    </LinearLayout>

    <TextView
        android:id="@+id/tvEmptyNotifications"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nema notifikacija."
        android:textColor="@color/text_secondary"
        android:textSize="15sp"
        android:gravity="center"
        android:visibility="gone"
        android:layout_marginTop="32dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvNotifications"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="12dp" />
</LinearLayout>