<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:id="@+id/llTargetNumber"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvTargetNumber"
            android:layout_width="120dp"
            android:layout_height="80dp"
            android:background="@drawable/bg_card"
            android:gravity="center"
            android:text="@string/target_number"
            android:textColor="@color/primary"
            android:textSize="32sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/llSmallNumbers"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/llTargetNumber"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNum1" style="@style/Widget.MaterialComponents.Button" android:layout_width="48dp" android:layout_height="64dp" tools:text="" android:contentDescription="Broj 1" app:cornerRadius="12dp" android:layout_margin="4dp" app:backgroundTint="@color/surface" app:strokeColor="@color/divider" app:strokeWidth="1dp" android:textColor="@color/primary" android:textStyle="bold" android:textSize="20sp"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNum2" style="@style/Widget.MaterialComponents.Button" android:layout_width="48dp" android:layout_height="64dp" tools:text="" android:contentDescription="Broj 2" app:cornerRadius="12dp" android:layout_margin="4dp" app:backgroundTint="@color/surface" app:strokeColor="@color/divider" app:strokeWidth="1dp" android:textColor="@color/primary" android:textStyle="bold" android:textSize="20sp"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNum3" style="@style/Widget.MaterialComponents.Button" android:layout_width="48dp" android:layout_height="64dp" tools:text="" android:contentDescription="Broj 3" app:cornerRadius="12dp" android:layout_margin="4dp" app:backgroundTint="@color/surface" app:strokeColor="@color/divider" app:strokeWidth="1dp" android:textColor="@color/primary" android:textStyle="bold" android:textSize="20sp"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNum4" style="@style/Widget.MaterialComponents.Button" android:layout_width="48dp" android:layout_height="64dp" tools:text="" android:contentDescription="Broj 4" app:cornerRadius="12dp" android:layout_margin="4dp" app:backgroundTint="@color/surface" app:strokeColor="@color/divider" app:strokeWidth="1dp" android:textColor="@color/primary" android:textStyle="bold" android:textSize="20sp"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNumMid" style="@style/Widget.MaterialComponents.Button" android:layout_width="56dp" android:layout_height="64dp" tools:text="" android:contentDescription="Srednji broj" app:cornerRadius="12dp" android:layout_margin="4dp" app:backgroundTint="@color/surface" app:strokeColor="@color/divider" app:strokeWidth="1dp" android:textColor="@color/primary" android:textStyle="bold" android:textSize="20sp"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNumLarge" style="@style/Widget.MaterialComponents.Button" android:layout_width="64dp" android:layout_height="64dp" tools:text="" android:contentDescription="Veliki broj" app:cornerRadius="12dp" android:layout_margin="4dp" app:backgroundTint="@color/surface" app:strokeColor="@color/divider" app:strokeWidth="1dp" android:textColor="@color/primary" android:textStyle="bold" android:textSize="20sp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/llOperators"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/llSmallNumbers"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOpPlus" style="@style/Widget.MaterialComponents.Button" android:layout_width="48dp" android:layout_height="56dp" android:text="+" android:contentDescription="Sabiranje" app:backgroundTint="@color/divider" android:textColor="@color/text_primary" app:cornerRadius="8dp" android:layout_margin="4dp"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOpMinus" style="@style/Widget.MaterialComponents.Button" android:layout_width="48dp" android:layout_height="56dp" android:text="-" android:contentDescription="Oduzimanje" app:backgroundTint="@color/divider" android:textColor="@color/text_primary" app:cornerRadius="8dp" android:layout_margin="4dp"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOpMul" style="@style/Widget.MaterialComponents.Button" android:layout_width="48dp" android:layout_height="56dp" android:text="*" android:contentDescription="Množenje" app:backgroundTint="@color/divider" android:textColor="@color/text_primary" app:cornerRadius="8dp" android:layout_margin="4dp"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOpDiv" style="@style/Widget.MaterialComponents.Button" android:layout_width="48dp" android:layout_height="56dp" android:text="/" android:contentDescription="Deljenje" app:backgroundTint="@color/divider" android:textColor="@color/text_primary" app:cornerRadius="8dp" android:layout_margin="4dp"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOpLeftParen" style="@style/Widget.MaterialComponents.Button" android:layout_width="48dp" android:layout_height="56dp" android:text="(" android:contentDescription="Leva zagrada" app:backgroundTint="@color/divider" android:textColor="@color/text_primary" app:cornerRadius="8dp" android:layout_margin="4dp"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOpRightParen" style="@style/Widget.MaterialComponents.Button" android:layout_width="48dp" android:layout_height="56dp" android:text=")" android:contentDescription="Desna zagrada" app:backgroundTint="@color/divider" android:textColor="@color/text_primary" app:cornerRadius="8dp" android:layout_margin="4dp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/llCalcScreenLayer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/llOperators"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvCalcScreen"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1"
            android:background="@drawable/bg_card"
            android:gravity="center_vertical|end"
            android:padding="16dp"
            android:text=""
            tools:text="15 * (10 + 2)"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBackspace"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginStart="16dp"
            android:contentDescription="Obriši"
            android:padding="0dp"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:icon="@drawable/ic_backspace"
            app:iconSize="32dp"
            app:iconTint="@color/surface"
            app:backgroundTint="@color/secondary"
            app:cornerRadius="12dp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/llActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/llCalcScreenLayer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnClearAll"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginEnd="16dp"
            android:contentDescription="Poništi sve"
            android:padding="0dp"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:icon="@drawable/ic_clear"
            app:iconSize="32dp"
            app:iconTint="@color/surface"
            app:backgroundTint="@color/secondary"
            app:cornerRadius="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirmCalc"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:contentDescription="Potvrdi rezultat"
            android:padding="0dp"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:icon="@drawable/ic_check"
            app:iconSize="32dp"
            app:iconTint="@color/surface"
            app:backgroundTint="@color/secondary"
            app:cornerRadius="12dp" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStopTarget"
        android:layout_width="wrap_content"
        android:layout_height="56dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="48dp"
        android:text="@string/stop"
        android:contentDescription="Stop"
        android:textStyle="bold"
        app:cornerRadius="28dp"
        android:textSize="16sp"
        app:backgroundTint="@color/secondary"
        android:textColor="@color/surface"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
