<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <GridLayout
        android:id="@+id/gridAssociations"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:columnCount="2"
        android:rowCount="3"
        android:layout_marginTop="18dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- A -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="vertical"
            android:layout_margin="4dp">

            <com.google.android.material.button.MaterialButton android:id="@+id/btnA1" style="@style/Widget.MaterialComponents.Button" android:layout_width="match_parent" android:layout_height="44dp" android:layout_margin="3dp" android:text="A1" android:textStyle="bold" android:textSize="13sp" android:textColor="@color/background" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp" android:insetLeft="0dp" android:insetRight="0dp" android:insetTop="0dp" android:insetBottom="0dp" app:cornerRadius="10dp" app:backgroundTint="@color/surface" app:strokeColor="@color/divider" app:strokeWidth="1dp" />
            <com.google.android.material.button.MaterialButton android:id="@+id/btnA2" style="@style/Widget.MaterialComponents.Button" android:layout_width="match_parent" android:layout_height="44dp" android:layout_margin="3dp" android:text="A2" android:textStyle="bold" android:textSize="13sp" android:textColor="@color/background" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp" android:insetLeft="0dp" android:insetRight="0dp" android:insetTop="0dp" android:insetBottom="0dp" app:cornerRadius="10dp" app:backgroundTint="@color/surface" app:strokeColor="@color/divider" app:strokeWidth="1dp" />
            <com.google.android.material.button.MaterialButton android:id="@+id/btnA3" style="@style/Widget.MaterialComponents.Button" android:layout_width="match_parent" android:layout_height="44dp" android:layout_margin="3dp" android:text="A3" android:textStyle="bold" android:textSize="13sp" android:textColor="@color/background" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp" android:insetLeft="0dp" android:insetRight="0dp" android:insetTop="0dp" android:insetBottom="0dp" app:cornerRadius="10dp" app:backgroundTint="@color/surface" app:strokeColor="@color/divider" app:strokeWidth="1dp" />
            <com.google.android.material.button.MaterialButton android:id="@+id/btnA4" style="@style/Widget.MaterialComponents.Button" android:layout_width="match_parent" android:layout_height="44dp" android:layout_margin="3dp" android:text="A4" android:textStyle="bold" android:textSize="13sp" android:textColor="@color/background" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp" android:insetLeft="0dp" android:insetRight="0dp" android:insetTop="0dp" android:insetBottom="0dp" app:cornerRadius="10dp" app:backgroundTint="@color/surface" app:strokeColor="@color/divider" app:strokeWidth="1dp" />

            <EditText
                android:id="@+id/etSolutionA"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_margin="3dp"
                android:hint="Rešenje A"
                android:gravity="center"
                android:textStyle="bold"
                android:textColor="@color/surface"
                android:textColorHint="@color/surface"
                android:backgroundTint="@color/divider" />
        </LinearLayout>

        <!-- B -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="vertical"
            android:layout_margin="4dp">

            <com.google.android.material.button.MaterialButton android:id="@+id/btnB1" style="@style/Widget.MaterialComponents.Button" android:layout_width="match_parent" android:layout_height="44dp" android:layout_margin="3dp" android:text="B1" android:textStyle="bold" android:textSize="13sp" android:textColor="@color/background" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp" android:insetLeft="0dp" android:insetRight="0dp" android:insetTop="0dp" android:insetBottom="0dp" app:cornerRadius="10dp" app:backgroundTint="@color/surface" app:strokeColor="@color/divider" app:strokeWidth="1dp" />
            <com.google.android.material.button.MaterialButton android:id="@+id/btnB2" style="@style/Widget.MaterialComponents.Button" android:layout_width="match_parent" android:layout_height="44dp" android:layout_margin="3dp" android:text="B2" android:textStyle="bold" android:textSize="13sp" android:textColor="@color/background" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp" android:insetLeft="0dp" android:insetRight="0dp" android:insetTop="0dp" android:insetBottom="0dp" app:cornerRadius="10dp" app:backgroundTint="@color/surface" app:strokeColor="@color/divider" app:strokeWidth="1dp" />
            <com.google.android.material.button.MaterialButton android:id="@+id/btnB3" style="@style/Widget.MaterialComponents.Button" android:layout_width="match_parent" android:layout_height="44dp" android:layout_margin="3dp" android:text="B3" android:textStyle="bold" android:textSize="13sp" android:textColor="@color/background" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp" android:insetLeft="0dp" android:insetRight="0dp" android:insetTop="0dp" android:insetBottom="0dp" app:cornerRadius="10dp" app:backgroundTint="@color/surface" app:strokeColor="@color/divider" app:strokeWidth="1dp" />
            <com.google.android.material.button.MaterialButton android:id="@+id/btnB4" style="@style/Widget.MaterialComponents.Button" android:layout_width="match_parent" android:layout_height="44dp" android:layout_margin="3dp" android:text="B4" android:textStyle="bold" android:textSize="13sp" android:textColor="@color/background" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp" android:insetLeft="0dp" android:insetRight="0dp" android:insetTop="0dp" android:insetBottom="0dp" app:cornerRadius="10dp" app:backgroundTint="@color/surface" app:strokeColor="@color/divider" app:strokeWidth="1dp" />

            <EditText
                android:id="@+id/etSolutionB"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_margin="3dp"
                android:hint="Rešenje B"
                android:gravity="center"
                android:textStyle="bold"
                android:textColor="@color/surface"
                android:textColorHint="@color/surface"
                android:backgroundTint="@color/divider" />
        </LinearLayout>

        <!-- Konačno rešenje u sredini -->
        <EditText
            android:id="@+id/etFinalSolution"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_columnSpan="2"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            android:hint="Konačno rešenje"
            android:gravity="center"
            android:textStyle="bold"
            android:textColor="@color/surface"
            android:textColorHint="@color/surface"
            android:backgroundTint="@color/warning" />

        <!-- C -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="vertical"
            android:layout_margin="4dp">

            <EditText
                android:id="@+id/etSolutionC"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_margin="3dp"
                android:hint="Rešenje C"
                android:gravity="center"
                android:textStyle="bold"
                android:textColor="@color/surface"
                android:textColorHint="@color/surface"
                android:backgroundTint="@color/divider" />

            <com.google.android.material.button.MaterialButton android:id="@+id/btnC4" style="@style/Widget.MaterialComponents.Button" android:layout_width="match_parent" android:layout_height="44dp" android:layout_margin="3dp" android:text="C4" android:textStyle="bold" android:textSize="13sp" android:textColor="@color/background" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp" android:insetLeft="0dp" android:insetRight="0dp" android:insetTop="0dp" android:insetBottom="0dp" app:cornerRadius="10dp" app:backgroundTint="@color/surface" app:strokeColor="@color/divider" app:strokeWidth="1dp" />
            <com.google.android.material.button.MaterialButton android:id="@+id/btnC3" style="@style/Widget.MaterialComponents.Button" android:layout_width="match_parent" android:layout_height="44dp" android:layout_margin="3dp" android:text="C3" android:textStyle="bold" android:textSize="13sp" android:textColor="@color/background" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp" android:insetLeft="0dp" android:insetRight="0dp" android:insetTop="0dp" android:insetBottom="0dp" app:cornerRadius="10dp" app:backgroundTint="@color/surface" app:strokeColor="@color/divider" app:strokeWidth="1dp" />
            <com.google.android.material.button.MaterialButton android:id="@+id/btnC2" style="@style/Widget.MaterialComponents.Button" android:layout_width="match_parent" android:layout_height="44dp" android:layout_margin="3dp" android:text="C2" android:textStyle="bold" android:textSize="13sp" android:textColor="@color/background" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp" android:insetLeft="0dp" android:insetRight="0dp" android:insetTop="0dp" android:insetBottom="0dp" app:cornerRadius="10dp" app:backgroundTint="@color/surface" app:strokeColor="@color/divider" app:strokeWidth="1dp" />
            <com.google.android.material.button.MaterialButton android:id="@+id/btnC1" style="@style/Widget.MaterialComponents.Button" android:layout_width="match_parent" android:layout_height="44dp" android:layout_margin="3dp" android:text="C1" android:textStyle="bold" android:textSize="13sp" android:textColor="@color/background" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp" android:insetLeft="0dp" android:insetRight="0dp" android:insetTop="0dp" android:insetBottom="0dp" app:cornerRadius="10dp" app:backgroundTint="@color/surface" app:strokeColor="@color/divider" app:strokeWidth="1dp" />
        </LinearLayout>

        <!-- D -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="vertical"
            android:layout_margin="4dp">

            <EditText
                android:id="@+id/etSolutionD"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_margin="3dp"
                android:hint="Rešenje D"
                android:gravity="center"
                android:textStyle="bold"
                android:textColor="@color/surface"
                android:textColorHint="@color/surface"
                android:backgroundTint="@color/divider" />

            <com.google.android.material.button.MaterialButton android:id="@+id/btnD4" style="@style/Widget.MaterialComponents.Button" android:layout_width="match_parent" android:layout_height="44dp" android:layout_margin="3dp" android:text="D4" android:textStyle="bold" android:textSize="13sp" android:textColor="@color/background" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp" android:insetLeft="0dp" android:insetRight="0dp" android:insetTop="0dp" android:insetBottom="0dp" app:cornerRadius="10dp" app:backgroundTint="@color/surface" app:strokeColor="@color/divider" app:strokeWidth="1dp" />
            <com.google.android.material.button.MaterialButton android:id="@+id/btnD3" style="@style/Widget.MaterialComponents.Button" android:layout_width="match_parent" android:layout_height="44dp" android:layout_margin="3dp" android:text="D3" android:textStyle="bold" android:textSize="13sp" android:textColor="@color/background" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp" android:insetLeft="0dp" android:insetRight="0dp" android:insetTop="0dp" android:insetBottom="0dp" app:cornerRadius="10dp" app:backgroundTint="@color/surface" app:strokeColor="@color/divider" app:strokeWidth="1dp" />
            <com.google.android.material.button.MaterialButton android:id="@+id/btnD2" style="@style/Widget.MaterialComponents.Button" android:layout_width="match_parent" android:layout_height="44dp" android:layout_margin="3dp" android:text="D2" android:textStyle="bold" android:textSize="13sp" android:textColor="@color/background" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp" android:insetLeft="0dp" android:insetRight="0dp" android:insetTop="0dp" android:insetBottom="0dp" app:cornerRadius="10dp" app:backgroundTint="@color/surface" app:strokeColor="@color/divider" app:strokeWidth="1dp" />
            <com.google.android.material.button.MaterialButton android:id="@+id/btnD1" style="@style/Widget.MaterialComponents.Button" android:layout_width="match_parent" android:layout_height="44dp" android:layout_margin="3dp" android:text="D1" android:textStyle="bold" android:textSize="13sp" android:textColor="@color/background" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp" android:insetLeft="0dp" android:insetRight="0dp" android:insetTop="0dp" android:insetBottom="0dp" app:cornerRadius="10dp" app:backgroundTint="@color/surface" app:strokeColor="@color/divider" app:strokeWidth="1dp" />
        </LinearLayout>

    </GridLayout>

    <LinearLayout
        android:id="@+id/llAssociationActions"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSubmitAnswer"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            app:backgroundTint="@color/warning"
            android:textColor="@color/surface"
            app:cornerRadius="12dp"
            android:text="Potvrdi odgovor"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>